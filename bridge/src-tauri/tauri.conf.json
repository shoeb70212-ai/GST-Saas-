{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "KhataLens Tally Bridge",
  "version": "0.1.0",
  "identifier": "com.khatalens.tally-bridge",
  "build": {
    "beforeDevCommand": "npm run dev --prefix ../ui",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build --prefix ../ui",
    "frontendDist": "../ui/dist"
  },
  "app": {
    "windows": [
      {
        "title": "KhataLens Tally Bridge",
        "width": 440,
        "height": 640,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "msi",
    "icon": []
  }
}
