diff --git a/backend/public_routes.py b/backend/public_routes.py
new file mode 100644
index 0000000..d0d886b
--- /dev/null
+++ b/backend/public_routes.py
@@ -0,0 +1,196 @@
+import os
+from typing import List
+
+import httpx
+from fastapi import APIRouter, BackgroundTasks, File, Form, HTTPException, UploadFile
+
+from main import SUPABASE_URL, run_ai_extraction
+from batch_routes import format_date_to_iso
+
+router = APIRouter()
+
+# This must be the Supabase *service role* key (Project Settings -> API),
+# never the anon key. The whole point of these two endpoints is to let an
+# unauthenticated visitor (a business owner with no KhataLens login) write
+# into an accountant's data on their behalf. RLS on `clients`/`invoices`
+# requires auth.uid() = user_id, which an anonymous visitor can never satisfy
+# - so a normal anon-key request would just silently fail. The service role
+# key bypasses RLS, which is why client_id is validated server-side before
+# any write, and why nothing from this file is ever exposed to the frontend.
+SUPABASE_SERVICE_ROLE_KEY = os.getenv("SUPABASE_SERVICE_ROLE_KEY")
+
+MAX_FILE_SIZE = 10 * 1024 * 1024   # 10MB per file
+MAX_TOTAL_SIZE = 50 * 1024 * 1024  # 50MB per submission
+VALID_EXTS = ('.jpg', '.jpeg', '.png', '.webp', '.pdf')
+
+
+def _service_headers() -> dict:
+    if not SUPABASE_SERVICE_ROLE_KEY:
+        raise HTTPException(
+            status_code=500,
+            detail="Server misconfigured: SUPABASE_SERVICE_ROLE_KEY is not set."
+        )
+    return {
+        "apikey": SUPABASE_SERVICE_ROLE_KEY,
+        "Authorization": f"Bearer {SUPABASE_SERVICE_ROLE_KEY}",
+        "Content-Type": "application/json",
+    }
+
+
+@router.get("/api/public/client/{client_id}")
+async def get_public_client_info(client_id: str):
+    """Unauthenticated lookup used only to show the client's name on the
+    portal page ('Send documents to {name}'). Returns nothing else."""
+    async with httpx.AsyncClient() as http_client:
+        resp = await http_client.get(
+            f"{SUPABASE_URL}/rest/v1/clients?id=eq.{client_id}&select=client_name",
+            headers=_service_headers()
+        )
+    if resp.status_code != 200 or not resp.json():
+        raise HTTPException(status_code=404, detail="Invalid portal link.")
+    return {"name": resp.json()[0].get("client_name") or "Your CA"}
+
+
+async def process_public_upload_worker(invoice_id: str, content: bytes, mime_type: str, owner_user_id: str):
+    headers = _service_headers()
+    try:
+        # Credits belong to the accountant, not the anonymous uploader. Check
+        # again here (not just at submission time) in case several files were
+        # queued and an earlier one in the batch used up what was left.
+        async with httpx.AsyncClient() as http_client:
+            profile_resp = await http_client.get(
+                f"{SUPABASE_URL}/rest/v1/profiles?id=eq.{owner_user_id}&select=credits",
+                headers=headers
+            )
+            credits = profile_resp.json()[0].get("credits", 0) if profile_resp.status_code == 200 and profile_resp.json() else 0
+
+        if credits <= 0:
+            async with httpx.AsyncClient() as http_client:
+                await http_client.patch(
+                    f"{SUPABASE_URL}/rest/v1/invoices?id=eq.{invoice_id}",
+                    headers=headers,
+                    json={"processing_status": "failed", "error_message": "Accountant's account is out of scan credits."}
+                )
+            return
+
+        data_dict = await run_ai_extraction(content, mime_type)
+
+        async with httpx.AsyncClient() as http_client:
+            await http_client.post(
+                f"{SUPABASE_URL}/rest/v1/rpc/decrement_credits",
+                headers=headers,
+                json={"user_id_param": owner_user_id}
+            )
+
+            db_update = {k.lower(): v for k, v in data_dict.items() if k != "Line_Items"}
+            if "invoice_date" in db_update:
+                db_update["invoice_date"] = format_date_to_iso(db_update["invoice_date"])
+            if "due_date" in db_update:
+                db_update["due_date"] = format_date_to_iso(db_update["due_date"])
+            db_update["processing_status"] = "completed"
+            db_update["error_message"] = None
+
+            await http_client.patch(
+                f"{SUPABASE_URL}/rest/v1/invoices?id=eq.{invoice_id}",
+                headers=headers,
+                json=db_update
+            )
+
+            line_items = data_dict.get("Line_Items", [])
+            if line_items:
+                items_payload = [{
+                    "invoice_id": invoice_id,
+                    "description": li.get("Description"),
+                    "hsn_sac": li.get("HSN_SAC"),
+                    "quantity": li.get("Quantity"),
+                    "unit_price": li.get("Unit_Price"),
+                    "tax_rate": li.get("Tax_Rate"),
+                    "amount": li.get("Amount"),
+                } for li in line_items]
+                resp = await http_client.post(
+                    f"{SUPABASE_URL}/rest/v1/invoice_line_items",
+                    headers=headers,
+                    json=items_payload
+                )
+                if resp.status_code not in (200, 201):
+                    raise Exception(f"Failed to insert line items: {resp.text}")
+
+    except Exception as e:
+        async with httpx.AsyncClient() as http_client:
+            await http_client.patch(
+                f"{SUPABASE_URL}/rest/v1/invoices?id=eq.{invoice_id}",
+                headers=headers,
+                json={"processing_status": "failed", "error_message": str(e)}
+            )
+
+
+@router.post("/api/public-upload")
+async def public_upload(
+    background_tasks: BackgroundTasks,
+    client_id: str = Form(...),
+    files: List[UploadFile] = File(...),
+):
+    # 1. Validate the portal link resolves to a real client, and find who owns it.
+    async with httpx.AsyncClient() as http_client:
+        client_resp = await http_client.get(
+            f"{SUPABASE_URL}/rest/v1/clients?id=eq.{client_id}&select=id,user_id",
+            headers=_service_headers()
+        )
+    if client_resp.status_code != 200 or not client_resp.json():
+        raise HTTPException(status_code=404, detail="Invalid portal link.")
+    owner_user_id = client_resp.json()[0]["user_id"]
+
+    # 2. Refuse upfront if the accountant has no credits left - no point queuing.
+    async with httpx.AsyncClient() as http_client:
+        profile_resp = await http_client.get(
+            f"{SUPABASE_URL}/rest/v1/profiles?id=eq.{owner_user_id}&select=credits",
+            headers=_service_headers()
+        )
+    credits = profile_resp.json()[0].get("credits", 0) if profile_resp.status_code == 200 and profile_resp.json() else 0
+    if credits <= 0:
+        raise HTTPException(status_code=402, detail="This accountant's account is out of scan credits right now. Please contact them directly.")
+
+    # 3. Validate + queue each file. Re-enforce the same limits the portal UI
+    #    already shows client-side, since this endpoint is public and untrusted.
+    total_size = 0
+    queued = 0
+    async with httpx.AsyncClient() as http_client:
+        for f in files:
+            content = await f.read()
+            fname_lower = (f.filename or "").lower()
+
+            if not fname_lower.endswith(VALID_EXTS):
+                continue
+            if len(content) > MAX_FILE_SIZE:
+                continue
+            total_size += len(content)
+            if total_size > MAX_TOTAL_SIZE:
+                break
+
+            mime_type = f.content_type or "application/octet-stream"
+
+            ins_resp = await http_client.post(
+                f"{SUPABASE_URL}/rest/v1/invoices",
+                headers={**_service_headers(), "Prefer": "return=representation"},
+                json={
+                    "user_id": owner_user_id,
+                    "client_id": client_id,
+                    "file_name": f.filename,
+                    "processing_status": "pending",
+                }
+            )
+            if ins_resp.status_code in (200, 201):
+                invoice_id = ins_resp.json()[0]["id"]
+                queued += 1
+                background_tasks.add_task(
+                    process_public_upload_worker,
+                    invoice_id=invoice_id,
+                    content=content,
+                    mime_type=mime_type,
+                    owner_user_id=owner_user_id,
+                )
+
+    if queued == 0:
+        raise HTTPException(status_code=400, detail="No valid files were uploaded. Use JPG, PNG, or PDF, under 10MB each.")
+
+    return {"status": "success", "queued": queued}
